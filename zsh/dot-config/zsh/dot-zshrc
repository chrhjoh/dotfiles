
ZSH_AUTOSUGGEST_STRATEGY=(history)


# oh-my-zsh extra settings for plugins

# oh-my-zsh configuration generated by NixOS
plugins=(git alias-finder docker python rust)


source $ZSH/oh-my-zsh.sh


HISTSIZE="10000"
SAVEHIST="10000"

HISTFILE="$XDG_DATA_HOME/zsh_history"
mkdir -p "$(dirname "$HISTFILE")"

setopt HIST_FCNTL_LOCK
unsetopt APPEND_HISTORY
setopt HIST_IGNORE_DUPS
unsetopt HIST_IGNORE_ALL_DUPS
setopt HIST_IGNORE_SPACE
unsetopt HIST_EXPIRE_DUPS_FIRST
setopt SHARE_HISTORY
unsetopt EXTENDED_HISTORY

# Starship
if [[ $TERM != "dumb" ]]; then
  eval "$(/opt/homebrew/bin/starship init zsh)"
fi

# Direnv
eval "$(/opt/homebrew/bin/direnv hook zsh)"

# Wezterm
if [[ -n "$WEZTERM_EXECUTABLE" ]]; then
    source "$XDG_CONFIG_HOME/zsh/wezterm.sh"
    
    function _run_prog() {
    # set PROG to the program being run
    __wezterm_set_user_var "PROG" "$1"

    # arrange to clear it when it is done
    trap '__wezterm_set_user_var PROG ""' EXIT

    # and now run the corresponding command, taking care to avoid looping
    # with the alias definition
    command "$@"
}
# Commands that Wezterm needs to know about
alias nvim="_run_prog nvim"
fi
HYPHEN_INSENSITIVE="true"
unsetopt beep
setopt COMBINING_CHARS

ZSH_AUTOSUGGEST_PARTIAL_ACCEPT_WIDGETS=+(vi-forward-word)
bindkey "^[[1;5C" vi-forward-word
bindkey "^[[1:5D" vi-backward-word

# >>> mamba initialize >>>
# !! Contents within this block are managed by 'mamba init' !!
export MAMBA_EXE='/opt/homebrew/bin/micromamba';
export MAMBA_ROOT_PREFIX='/Users/hcq343/.local/share/micromamba';
__mamba_setup="$("$MAMBA_EXE" shell hook --shell zsh --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__Xmamba_setup"
else
    alias micromamba="$MAMBA_EXE"  # Fallback on help from mamba activate
fi
unset __mamba_setup
# <<< mamba initialize <<<

# Aliases
alias -- dots='cd $DOTFILES'
alias -- mm=micromamba

# Named Directory Hashes

source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
ZSH_HIGHLIGHT_HIGHLIGHTERS+=()




